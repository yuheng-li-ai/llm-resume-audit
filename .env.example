# ============================================================================
# llm-resume-audit — environment template
# Copy to `.env` (git-ignored) and fill in real values. Never commit `.env`.
# ============================================================================

# Zhipu Open Platform (https://open.bigmodel.cn/usercenter/apikeys)
# Used by: src/llm_audit/scoring/zhipu_client.py for GLM 5.1, GLM-4 Flash.
ZHIPUAI_API_KEY=

# Google AI Studio (https://aistudio.google.com/app/apikey)
# Used by: src/llm_audit/scoring/gemini_client.py for Gemini 2.5 Flash.
# Free tier: 15 RPM, 1500 RPD, 1M TPM.
GOOGLE_AI_STUDIO_API_KEY=

# Groq Cloud (https://console.groq.com/keys)
# Used by: src/llm_audit/scoring/groq_client.py for Llama 3.3 70B Versatile.
# Free tier: 30 RPM, ~500K tokens/day (binding constraint on wall-clock).
GROQ_API_KEY=

# OSF — Open Science Framework (https://osf.io/settings/tokens)
# Used by: Phase 6 pre-registration uploader. Scope required: osf.full_write.
OSF_TOKEN=
